@inherits LayoutComponentBase
@using TestAssignment.Web.Services
@inject SessionState Session
@inject IdentityApiClient IdentityApi
@inject NavigationManager Navigation

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (Session.IsAuthenticated)
            {
                <span class="me-3">Hello, @Session.Login</span>
                <button class="btn btn-link" @onclick="HandleLogout">Logout</button>
            }
            else
            {
                <a href="/login">Login</a>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private async Task HandleLogout()
    {
        if (Session.IsAuthenticated)
        {
            try
            {
                await IdentityApi.LogoutAsync(Session.AccessToken!);
            }
            catch
            {
                // Best effort — clear session regardless.
            }

            Session.Clear();
        }

        Navigation.NavigateTo("/login");
    }
}
